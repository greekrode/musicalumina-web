# =============================================================================
# Musica Lumina — environment variables
# Copy this file to `.env` (local dev) and set matching values in Vercel
# (production). Every `VITE_*` variable is BAKED INTO THE CLIENT BUNDLE at
# build time and readable by anyone who views the site source.
# =============================================================================
#
# ⚠️  KNOWN ARCHITECTURAL RISK — tracked for follow-up PR.
#
# Three variables below (`VITE_N8N_USERNAME`, `VITE_N8N_PASSWORD`,
# `VITE_JWT_SECRET`) hold credentials that should not be client-side:
#
#   - The n8n basic-auth pair grants write access to the Lark Base
#     registration mirror. Anyone reading the bundle can call the
#     webhook directly.
#   - `VITE_JWT_SECRET` is an HS256 signing secret. The whole point of
#     HS256 is that the secret stays on the server — leaking it lets
#     anyone mint valid tokens.
#
# Correct fix (separate PR): proxy the Lark access-token + registration
# mirror + video-submission calls through a Supabase Edge Function (or
# a Vercel serverless route) that holds the secrets server-side and
# exposes an authenticated, scoped API to the browser. The three
# variables below should then be renamed WITHOUT the `VITE_` prefix
# and the client code updated to call the new endpoint.
#
# Until that lands, rotate these credentials aggressively and ensure
# the n8n webhook enforces per-IP rate limiting + an allowlist.
# =============================================================================

# ---- Supabase (required) ----
# PostgreSQL + Storage + Edge Functions. Anon key is public-safe — RLS
# is what protects the data; do not swap this for the service role key.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- Clerk (required) ----
# Admin authentication. Publishable key is public-safe by design.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxx

# ---- TinyMCE (required for admin) ----
# Rich-text editor in admin modals (Category / Subcategory / Jury / Events).
# Public site never loads TinyMCE — admin routes are lazy.
VITE_TINYMCE_API_KEY=your-tinymce-api-key

# ---- n8n / Lark bridge (⚠️ client-exposed — see warning above) ----
# Basic-auth credentials for the n8n webhooks that proxy Lark Base writes
# (registration mirror + video submission). Username/password pair.
VITE_N8N_USERNAME=your-n8n-basic-auth-username
VITE_N8N_PASSWORD=your-n8n-basic-auth-password

# ---- JWT (⚠️ client-exposed — see warning above) ----
# HS256 secret used to sign requests to the Lark access-token webhook.
# Must match the server-side verifier. Rotate on every deploy until this
# is moved server-side.
VITE_JWT_SECRET=your-jwt-signing-secret
